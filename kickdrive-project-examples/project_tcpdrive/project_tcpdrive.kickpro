<?xml version='1.0' encoding='UTF-8'?>
<KickdriveProject>
 <module panelVisible="1" label="Project Home" type="project">
  <docs>
   <default>
    <html>
     <head>
      <meta content="text/html; charset=ISO-8859-1" http-equiv="content-type">
       <title>MovingCap Ethernet Drives</title>
      </meta>
      <link rel="stylesheet" type="text/css" href="template.css"/>
     </head>
     <body>
      <h1>MovingCap Ethernet Drives</h1>
      <p>A project template for setup and service of MovingCap Ethernet drives.</p>
      <p>How to Use</p>
      <ul>
       <li>Connect your PC with your Ethernet drive via network</li>
       <li>Make sure your Ethernet drive and your computer PC are in the same IP subnet.<br/>
	   MovingCAP's default IPv4 address is <strong>192.168.2.150</strong> - you could set your PC network interface to IPv4 address 192.168.2.10 
       and IP subnet prefix length 24 (or Subnet 255.255.255.0)
	   for example.)</li>
       <li>Open the <a href="#app:panel,Communication">Communication</a> module and check if the IP address is the same as your MovingCap Ethernet drive.<br/>
	   TIP: The status LED of MovingCap Ethernet uses Morse code to indicate the currently used IP address. You can use
	   a Morse app for your smartphone to decode the blinking LED and show the actual IP.
	   </li>
       <li>Switch on power supply for the MovingCap drive.</li>
       <li>Go to <a href="#app:panel,MC Eth Drive - Setup">MC Eth Drive - Setup</a> and click 'Start Drive'.</li>
       <li>Use <a href="#app:panel,MC Eth Drive - Object Editor">MC Eth Drive - Object Editor</a> to view or modify specific DS402 drive parameters.</li>
       <li>Open <a href="#app:panel,Scope">Scope</a>, drag one or more parameter(s) from the Object Editor to the 'Scope' 
	   area and press 'Start' for sampling. Double click on the parameter creates a plot.
	   	<br/>
	    Use the 'Record' button to store the sampled data into a file. (The file is by default stored along with the %%AppTitle%% project data.) Use the 'Open' button from the Scope toolbar to load and view such a recording. Use 'Save Project' from the main toolbar to store all relevant data into a '.kickzip' project file.	   &#xd;&#xd;&#xd;&#xd;&#xd;
	   <br/>
	   Using <a href="#app:panel,Scope - Trigger">Scope - Trigger</a> you can define trigger events to record only measurements immediately before and &#xd;&#xd;&#xd;&#xd;&#xd;
	   after a trigger event. 
	   </li>
      </ul>
     </body>
    </html>
   </default>
  </docs>
  <module description="Allows CAN-style communication via TCP or CAN bus" panelVisible="0" label="Communication" type="canusb">
   <module panelVisible="0" label="CAN Monitor" type="canmonitor"/>
   <properties>
    <Port>net:192.168.2.150:15001</Port>
    <Baudrate>250K</Baudrate>
    <DebugMode>0</DebugMode>
    <MonitorFilter0>id = 81-ff # emergency msg only</MonitorFilter0>
    <MonitorFilter1>id != 81-ff # hide emergency msg</MonitorFilter1>
    <MonitorFilter2>dir = tx # tx data only</MonitorFilter2>
    <MonitorFilter3>exclude index = 6063, index = 606c # hide pos/velocity readout</MonitorFilter3>
    <MonitorFilter4>index = 6041 # show drive status only</MonitorFilter4>
    <MonitorFilter5>data = 80 * # show SDO abort transfer / error codes</MonitorFilter5>
   </properties>
  </module>
  <module description="Scope / Data Logger" panelVisible="0" label="Scope" userLevel="1" type="datalog" dragDropMode="1">
   <module panelVisible="0" label="Trigger" type="trigger"/>
   <docs>
    <DisplayedKickPlots>
     <Containers/>
    </DisplayedKickPlots>
    <MonitoringObjects>
     <CANopenObjectList>
      <CANopenObject objectType="7" kickScaling="" monitorInterval="10" kickUiFormat="updates:r200; shape:slider; range:-32768,32768; step:1" dataType="0004" actualValue="-8531" index="6064" nodeId="50" name="Position actual value" PDOmapping="TPDO" uniqueIDRef="UID_PARAM_6064"/>
     </CANopenObjectList>
    </MonitoringObjects>
   </docs>
   <properties>
    <TriggerConfig>001.606ch.00h > 10;001.6041h.00h</TriggerConfig>
    <PreTriggerTimeMsec>1000</PreTriggerTimeMsec>
    <PostTriggerTimeMsec>2000</PostTriggerTimeMsec>
    <TriggerState>0</TriggerState>
   </properties>
   <module description="Scope Panel" panelVisible="0" label="Pos" userLevel="1" type="datalog_plot">
    <docs>
     <PlotConfigurationDoc>
      <PlotConfiguration yScale="a" title="Pos" xScale="6" cursorPosition="12.2">
       <Curves>
        <CurveConfiguration colorName="#000080" dataObjectId="050.6064h.00h" objectName="050.6064h.00h Position actual value"/>
       </Curves>
      </PlotConfiguration>
     </PlotConfigurationDoc>
    </docs>
   </module>
   <slave label="Communication" type="canusb"/>
  </module>
